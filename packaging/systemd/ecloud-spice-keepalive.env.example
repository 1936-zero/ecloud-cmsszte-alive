# public-ecloud SPICE keepalive env (path-only secrets)
# Copy to ecloud-spice-keepalive.env and adjust.
# NEVER put token / plain / password contents here — only paths and host.

# Optional: leave empty to resolve from cloud_pc.json / gateway defaults
HOST=
# ConnectStr plain file (chmod 600). Path only.
PLAIN=%h/.cache/ecloud-pathb/connectstr.plain
# Prefer shipped templates under repo
PRE=
POST=
INTERVAL=300
HEART=60
OUT_DIR=%h/.cache/ecloud-pathb/keepalive-out
TICKET_MODE=zeros
# REPO is auto-detected by bin/public-spice-keepalive; set only if needed
# REPO=/path/to/ecloud-cmsszte-alive

# product_line=public-ecloud
# forbid_jtydn=true forbid_aijia=true
# production_claim=false dual_evidence_ok=false
