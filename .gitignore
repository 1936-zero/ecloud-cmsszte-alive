# unit tests tracked (was ignored; broke clone-side unittest)
# pycache still covered by global __pycache__/ rules below
nest/

# Runtime / cache
.cache/
**/.cache/
# data/* runtime (accounts/tokens) — ignore contents; MUST use data/* not data/
# so git still descends and can un-ignore product installinfo for Path B (A/B local)
data/*
!data/config/
data/config/*
!data/config/installinfo.ini
*.log
keepalive.log

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# (no second data/ rule — would re-ignore installinfo)

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

